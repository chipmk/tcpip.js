{
  "name": "@tcpip/dhcp",
  "version": "0.2.4",
  "description": "DHCP server built on tcpip.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/chipmk/tcpip.js.git",
    "directory": "packages/dhcp"
  },
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup --clean",
    "clean": "rm -rf dist",
    "test": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@tcpip/wire": "workspace:*"
  },
  "peerDependencies": {
    "tcpip": "workspace:*"
  },
  "devDependencies": {
    "@total-typescript/tsconfig": "catalog:",
    "tcpip": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
