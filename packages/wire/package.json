{
  "name": "@tcpip/wire",
  "version": "0.1.4",
  "description": "Wire protocol utilities for tcpip.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/chipmk/tcpip.js.git",
    "directory": "packages/wire"
  },
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup --clean",
    "clean": "rm -rf dist",
    "test": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.cjs"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@total-typescript/tsconfig": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
